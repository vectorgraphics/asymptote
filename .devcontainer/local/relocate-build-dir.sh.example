#!/usr/bin/env bash
#
# Example dev-container hook (committed template). Copy it to
# `relocate-build-dir.sh` in this directory to enable it; post-create.sh then
# runs it on every (re)provision (the `.example` suffix keeps this template
# itself inert). See .devcontainer/README.md ("Out-of-workspace build
# directory").
#
# Puts the CMake build tree OUTSIDE the bind-mounted workspace so that binaries
# linked against the container's libraries are not visible from -- and so cannot
# be accidentally launched on -- the host.
#
# The build root lives under ~/.local, on the container's own (tmpfs) filesystem
# alongside the container-local Claude install and Python venv. Like those, the
# artifacts here are disposable: they get rebuilt no more often than the
# container itself is recreated, and the persistent ccache volume keeps any
# rebuild cheap, so we make no effort to persist them across rebuilds.
#
# Safe to re-run. It will NOT overwrite a hand-written CMakeUserPresets.json
# (e.g. personal debug presets -- see .devcontainer/README.md).
set -euo pipefail

WORKSPACE_DIR="${WORKSPACE_DIR:-/workspaces/asymptote}"
BUILD_ROOT="$HOME/.local/asy-build"
PRESETS_FILE="$WORKSPACE_DIR/CMakeUserPresets.json"

# Identifies files this script generated, so re-runs may regenerate them while a
# developer's own CMakeUserPresets.json is left untouched.
MARKER="asymptote.devcontainer/out-of-workspace-build-dir"

mkdir -p "$BUILD_ROOT"

if [ -e "$PRESETS_FILE" ] && ! grep -qsF "$MARKER" "$PRESETS_FILE"; then
    cat >&2 <<EOF
[relocate-build-dir] $PRESETS_FILE already exists and was not generated by this
script -- leaving it untouched. To build outside the workspace, add a
configurePreset that inherits "linux/release" with:
    "binaryDir": "$BUILD_ROOT/release"
EOF
    exit 0
fi

# CMakeUserPresets.json is gitignored. It inherits the project presets from
# CMakePresets.json and only overrides binaryDir (plus enables ccache, whose
# cache is a persistent volume). The "/devcontainer" suffix keeps the names
# distinct from the shipped "linux/release"/"linux/sandbox", so these never
# shadow host builds.
#
# Two presets are generated:
#   linux/release/devcontainer  -- the full vcpkg build, relocated out of the
#       bind mount (needs network on first configure to fetch vcpkg deps).
#   linux/sandbox/devcontainer  -- the system-deps-only build (no vcpkg, no
#       network), relocated likewise. This is the one usable from the no-network
#       bash sandbox; it needs the extra system dev libraries installed by the
#       Dockerfile (libglm-dev, libgsl-dev, libcurl4-openssl-dev,
#       libreadline-dev, libncurses-dev).
#       CMAKE_POLICY_VERSION_MINIMUM=3.5 is set because Ubuntu 22.04's
#       libglm-dev ships a glmConfig.cmake whose cmake_minimum_required predates
#       3.5, which the image's modern CMake (>= 4) otherwise refuses to load.
#
# Both presets set ENABLE_RELOCATABLE=ON. These binaries are run in place from
# their out-of-workspace build dir and never installed to the compiled-in
# ASYMPTOTE_SYSDIR (/usr/local/share/asymptote), so without this they fail with
# "could not load module 'plain'". ENABLE_RELOCATABLE makes initSysdir() fall
# back to base/ next to the binary when ASYMPTOTE_SYSDIR is absent. It is set on
# both presets identically so the sandbox build keeps behaving like the release
# build; the shipped (non-devcontainer) presets leave it off, matching a normal
# installed-to-prefix production build.
cat > "$PRESETS_FILE" <<EOF
{
  "version": 6,
  "vendor": {
    "$MARKER": "Generated by .devcontainer/local/relocate-build-dir.sh; regenerated on container (re)provision. Delete this file to opt out."
  },
  "configurePresets": [
    {
      "name": "linux/release/devcontainer",
      "displayName": "[linux-x86/64] Release (dev container, out-of-workspace build dir)",
      "inherits": [
        "linux/release",
        "base/linuxCcache"
      ],
      "binaryDir": "$BUILD_ROOT/release",
      "cacheVariables": {
        "ENABLE_RELOCATABLE": "ON"
      }
    },
    {
      "name": "linux/sandbox/devcontainer",
      "displayName": "[linux-x86/64] Sandbox (dev container, out-of-workspace build dir)",
      "inherits": [
        "linux/sandbox",
        "base/linuxCcache"
      ],
      "binaryDir": "$BUILD_ROOT/sandbox",
      "cacheVariables": {
        "CMAKE_POLICY_VERSION_MINIMUM": "3.5",
        "ENABLE_RELOCATABLE": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux/release/devcontainer",
      "displayName": "[linux-x86/64] Release (dev container)",
      "configurePreset": "linux/release/devcontainer",
      "inherits": [
        "build-base/linux-only"
      ]
    },
    {
      "name": "linux/sandbox/devcontainer",
      "displayName": "[linux-x86/64] Sandbox (dev container)",
      "configurePreset": "linux/sandbox/devcontainer",
      "inherits": [
        "build-base/linux-only"
      ]
    }
  ]
}
EOF

echo "[relocate-build-dir] wrote $PRESETS_FILE"
echo "[relocate-build-dir] release build dir -> $BUILD_ROOT/release (preset: linux/release/devcontainer)"
echo "[relocate-build-dir] sandbox build dir -> $BUILD_ROOT/sandbox (preset: linux/sandbox/devcontainer)"
